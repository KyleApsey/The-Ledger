    {
      "name": "Hot Buttered Rum",
      "base_yield_liters": 1,
      "notes": "Seasonal. Rest 24 hours before serving.",
      "ingredients": [
        { "name": "unsalted butter",  "quantity": 1,   "unit": "lbs"      },
        { "name": "brown sugar",      "quantity": 2,   "unit": "cups"     },
        { "name": "cinnamon",         "quantity": 1,   "unit": "teaspoon" },
        { "name": "nutmeg",           "quantity": 0.5, "unit": "teaspoon" },
        { "name": "allspice",         "quantity": 0.5, "unit": "teaspoon" },
        { "name": "rum",              "quantity": 750, "unit": "ml"       }
